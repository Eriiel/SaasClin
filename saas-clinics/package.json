{
  "name": "saas-clinics",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @saas-clinics/db prisma generate",
    "db:migrate": "pnpm --filter @saas-clinics/db prisma migrate dev",
    "db:studio": "pnpm --filter @saas-clinics/db prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
